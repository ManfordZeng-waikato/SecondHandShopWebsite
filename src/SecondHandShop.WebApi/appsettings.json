{
  "HttpsPort": 7266,
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5288"
      },
      "Https": {
        "Url": "https://0.0.0.0:7266"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=SecondHandShopDb;Username=postgres;Password=postgres;"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:5173"
    ]
  },
  "Email": {
    "Smtp": {
      "Enabled": false,
      "Host": "smtp.example.com",
      "Port": 587,
      "UseSsl": true,
      "Username": "",
      "Password": "",
      "FromEmail": "",
      "FromName": "SecondHandShop",
      "AdminInboxEmail": "",
      "FrontendBaseUrl": "https://localhost:5173"
    }
  },
  "R2": {
    "AccountId": "",
    "AccessKeyId": "",
    "SecretAccessKey": "",
    "BucketName": "",
    "WorkerBaseUrl": ""
  },
  "RemoveBg": {
    "ApiKey": "",
    "TimeoutSeconds": 30,
    "MaxRetries": 1,
    "MaxFileSizeBytes": 10485760
  },
  "CloudflareTurnstile": {
    "SiteKey": "",
    "SecretKey": "",
    "VerifyUrl": "https://challenges.cloudflare.com/turnstile/v0/siteverify"
  },
  "Analytics": {
    "AttributionWindowDays": 30
  },
  "Jwt": {
    "Issuer": "SecondHandShop",
    "Audience": "SecondHandShopUsers",
    "Key": "REPLACE_WITH_ENV_VARIABLE_AT_LEAST_32_CHARS",
    "AccessTokenMinutes": 20,
    "SlidingRenewalFraction": 0.5
  },
  "AdminSeed": {
    "UserName": "admin",
    "Password": "ChangeThisInProduction"
  },
  "ReverseProxy": {
    "TrustAllProxies": false,
    "KnownProxies": [],
    "KnownNetworks": []
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:O} {Level:u3}] [{CorrelationId}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
